{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch tests",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/build/tests",
            "preLaunchTask": "Build tests"
        },
        {
            "name": "Launch tests (CMake Tools)",
            "type": "cppdbg",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${cmake.testProgram}",
            "args": [
                "${cmake.testArgs}"
            ],
        },
    ]
}
